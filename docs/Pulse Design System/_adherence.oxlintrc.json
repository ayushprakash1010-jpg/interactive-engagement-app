{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/activity/**",
              "components/ai/**",
              "components/core/**",
              "ui_kits/host/**",
              "ui_kits/marketing/**",
              "ui_kits/participant/**",
              "ui_kits/projector/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ActivityTile> doesn't accept that prop. Declared props: icon, title, description, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|gradient|size|style|key|ref|className|style|children)$/]",
        "message": "<AIBadge> doesn't accept that prop. Declared props: label, gradient, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<AIBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AIComposer'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|onGenerate|placeholder|suggestions|loading|style|key|ref|className|style|children)$/]",
        "message": "<AIComposer> doesn't accept that prop. Declared props: value, onChange, onGenerate, placeholder, suggestions, loading, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AITheme'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|count|key|ref|className|style|children)$/]",
        "message": "<AITheme> doesn't accept that prop. Declared props: label, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|anonymous|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, anonymous, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Avatar> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|loading|iconLeft|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, loading, iconLeft, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|padding|tone|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, padding, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|raised|ai|dashed)$/]",
        "message": "<Card> tone must be one of 'default' | 'raised' | 'ai' | 'dashed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|label|active|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, label, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline|brand)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|code|size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, code, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='JoinCode'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|size|onCopy|inverse|style|key|ref|className|style|children)$/]",
        "message": "<JoinCode> doesn't accept that prop. Declared props: code, size, onCopy, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='JoinCode'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<JoinCode> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LeaderboardRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|name|points|you|inverse|style|key|ref|className|style|children)$/]",
        "message": "<LeaderboardRow> doesn't accept that prop. Declared props: rank, name, points, you, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|color|live|style|key|ref|className|style|children)$/]",
        "message": "<LiveDot> doesn't accept that prop. Declared props: size, color, live, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PollResult'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|count|total|index|leading|inverse|style|key|ref|className|style|children)$/]",
        "message": "<PollResult> doesn't accept that prop. Declared props: label, count, total, index, leading, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuestionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|author|votes|voted|onUpvote|status|answered|inverse|style|key|ref|className|style|children)$/]",
        "message": "<QuestionCard> doesn't accept that prop. Declared props: text, author, votes, voted, onUpvote, status, answered, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuestionCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:pending|approved)$/]",
        "message": "<QuestionCard> status must be one of 'pending' | 'approved'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|sub|icon|tone|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, label, sub, icon, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|brand|ai)$/]",
        "message": "<Stat> tone must be one of 'default' | 'brand' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SuggestionChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|onAccept|onDismiss|icon|style|key|ref|className|style|children)$/]",
        "message": "<SuggestionChip> doesn't accept that prop. Declared props: text, onAccept, onDismiss, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|disabled|label|size|id|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, disabled, label, size, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Switch> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, hint."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
