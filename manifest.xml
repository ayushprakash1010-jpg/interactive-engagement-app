<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Office Add-in Manifest for "Pulse for PowerPoint"

  HOW TO SIDELOAD (Development):
  ─────────────────────────────────────────────────
  PowerPoint Desktop (Windows):
    1. Go to File > Options > Trust Center > Trust Center Settings
    2. Select "Trusted Add-in Catalogs"
    3. Add a network share or use: Insert > Get Add-ins > Upload My Add-in

  PowerPoint Desktop (Mac):
    1. Go to Insert > Add-ins > My Add-ins > Upload My Add-in

  PowerPoint on the Web:
    1. Go to Insert > Add-ins > Upload My Add-in

  BEFORE SIDELOADING:
  ─────────────────────────────────────────────────
  1. Update <SourceLocation> below to match your development URL
     (e.g., https://causal-kitten-mountable.ngrok-free.dev/powerpoint)
  2. Make sure your ngrok/tunnel is running so PowerPoint can reach the task pane URL.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- ─── Identity ─────────────────────────────────────────── -->
  <!-- IMPORTANT: Generate a fresh GUID for production. Never share GUIDs between add-ins. -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Pulse (IEP)</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Pulse for PowerPoint" />
  <Description DefaultValue="Bring live polls and Q&amp;A to your PowerPoint presentations with Pulse." />

  <!-- ─── Icons ─────────────────────────────────────────────── -->
  <!-- Replace with your hosted icon URLs before publishing to AppSource -->
  <IconUrl DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/icons/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/icons/icon-80.png" />

  <!-- ─── Support URL (required for AppSource) ─────────────── -->
  <SupportUrl DefaultValue="https://causal-kitten-mountable.ngrok-free.dev" />

  <!-- ─── Permissions ──────────────────────────────────────── -->
  <!-- ReadWriteDocument: needed to read document.id (presentation URL) via getFilePropertiesAsync -->
  <Permissions>ReadWriteDocument</Permissions>

  <!-- ─── Host Requirements ────────────────────────────────── -->
  <Hosts>
    <Host Name="Presentation" />
  </Hosts>

  <!-- ─── Default settings ─────────────────────────────────── -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/powerpoint" />
  </DefaultSettings>

  <!-- ─── Version Overrides (VersionOverrides v1.0) ────────── -->
  <!-- This section enables the modern Ribbon button that opens the task pane -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">

    <Hosts>
      <Host xsi:type="Presentation">
        <DesktopFormFactor>

          <!-- The add-in commands add a button to the PowerPoint Ribbon -->
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="PulseGroup">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>

                <!-- Ribbon button to open the Pulse task pane -->
                <Control xsi:type="Button" id="OpenPulseTaskPane">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.SupertipTitle" />
                    <Description resid="TaskpaneButton.SupertipDescription" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>PulseTaskPane</TaskpaneId>
                    <SourceLocation resid="TaskpaneUrl" />
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- ─── Shared Resources ──────────────────────────────── -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/icons/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/icons/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/icons/icon-80.png" />
      </bt:Images>

      <bt:Urls>
        <bt:Url id="TaskpaneUrl" DefaultValue="https://causal-kitten-mountable.ngrok-free.dev/powerpoint" />
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Pulse" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open Pulse" />
        <bt:String id="TaskpaneButton.SupertipTitle" DefaultValue="Pulse Live Engagement" />
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="TaskpaneButton.SupertipDescription" DefaultValue="Open the Pulse task pane to run live polls and Q&amp;A alongside your presentation." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
