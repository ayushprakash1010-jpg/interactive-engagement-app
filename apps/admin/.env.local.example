# Pulse Admin Console — Local Environment
# Copy to .env.local and fill in values. Never commit .env.local to git.

# --- Auth0 (Dedicated Admin Auth0 Application) ---
# Create a new Regular Web Application in your Auth0 tenant for the Admin Console.
# Use these callback URLs in the Auth0 dashboard:
#   Allowed Callback URLs:
#     http://localhost:3001/api/auth/callback, https://admin.questliv.com/api/auth/callback
#   Allowed Logout URLs:
#     http://localhost:3001, https://admin.questliv.com
#   Allowed Web Origins:
#     http://localhost:3001, https://admin.questliv.com
#   Application Login URI:
#     http://localhost:3001
#
AUTH0_SECRET='generate-with: openssl rand -hex 32'
AUTH0_BASE_URL='http://localhost:3001'
AUTH0_ISSUER_BASE_URL='https://YOUR_TENANT.auth0.com'
AUTH0_CLIENT_ID='YOUR_ADMIN_APP_CLIENT_ID'
AUTH0_CLIENT_SECRET='YOUR_ADMIN_APP_CLIENT_SECRET'
AUTH0_AUDIENCE='YOUR_API_AUDIENCE'

# --- NestJS API ---
# Client-side: used to display API URL (not for direct browser requests — proxy handles auth)
NEXT_PUBLIC_API_URL='http://localhost:4000'
# Server-side: used by the Next.js proxy route to reach the API (Docker: http://api:4000)
API_INTERNAL_URL='http://localhost:4000'
