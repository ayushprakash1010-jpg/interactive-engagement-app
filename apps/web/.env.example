# ---- apps/web environment ----

# Base URL of the NestJS API as seen by the BROWSER (server + client)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Base URL of the API for SERVER-SIDE calls (BFF proxy, SSR). In docker this is
# the internal hostname (http://api:4000); leave unset for local `pnpm dev`.
# API_INTERNAL_URL=http://api:4000

# Socket.IO server URL (defaults to the API URL if unset)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Public base URL of this web app (used to build participant join links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Auth0 (REQUIRED from Sprint 1) ----
# The @auth0/nextjs-auth0 SDK reads these to run Universal Login and to mint
# access tokens for apps/api. Configure a Regular Web Application in Auth0 and
# set the callback to {AUTH0_BASE_URL}/api/auth/callback and logout to
# {AUTH0_BASE_URL}.
# Long random value used to encrypt the session cookie (openssl rand -hex 32)
AUTH0_SECRET=
# This app's base URL
AUTH0_BASE_URL=http://localhost:3000
# Your Auth0 tenant issuer, e.g. https://your-tenant.us.auth0.com
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# API identifier so the SDK requests an access token for apps/api.
# MUST match apps/api's AUTH0_AUDIENCE.
AUTH0_AUDIENCE=
