# ---- apps/api environment ----

# HTTP port the API + Socket.IO server listens on
PORT=4000

# Node environment: development | test | production
NODE_ENV=development

# MongoDB connection string (local docker-compose default shown)
MONGODB_URI=mongodb://localhost:27017/iep

# Redis connection string (Socket.IO adapter, counters, rate limiting)
REDIS_URL=redis://localhost:6379

# Allowed browser origin for CORS (the web app)
WEB_ORIGIN=http://localhost:3000

# The Admin Portal URL for CORS (e.g. https://admin.questliv.com)
ADMIN_PORTAL_URL=

# Web app URL used for OAuth callback redirects
FRONTEND_URL=http://localhost:3000

# ---- Auth0 (REQUIRED from Sprint 1) ----
# The JwtStrategy reads these at boot via getOrThrow; the API will not start
# until both are set. The web app must request access tokens for this audience.
# Your Auth0 tenant issuer, e.g. https://your-tenant.us.auth0.com/
AUTH0_ISSUER_BASE_URL=
# The API identifier (audience) configured in Auth0
AUTH0_AUDIENCE=

# ---- Rate limiting (wired in Sprint 7) ----
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# ---- Analytics PDF export (Sprint 6) ----
# Optional. Path to a Chromium/Chrome binary for puppeteer to render report PDFs.
# Leave blank to use the Chromium puppeteer downloads at install time (the
# default). Set this only on slim images that rely on a system-installed
# Chromium, e.g. /usr/bin/chromium-browser.
PUPPETEER_EXECUTABLE_PATH=

# ---- Zoom Integration ----
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=

# ---- Microsoft Teams Integration ----
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_REDIRECT_URI=

# Google Meet Integration
GOOGLE_MEET_CLIENT_ID=
GOOGLE_MEET_CLIENT_SECRET=
GOOGLE_MEET_REDIRECT_URI=
# Use "common" for work/school plus personal Microsoft accounts.
# Use "organizations" for work/school accounts only, "consumers" for personal
# accounts only, or a tenant ID/domain for a single-tenant app.
TEAMS_TENANT_ID=common
